# ── LLM（至少配置一个，妙喵首选 Kimi）──────────────
MOONSHOT_API_KEY=sk-...
# 回退用
DEEPSEEK_API_KEY=sk-...

# ── 百度短语音识别（语音输入必需）──────────────────
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# ── 管理后台（不设置则启动时随机生成并打印到日志）───
ADMIN_TOKEN=

# ── 数据路径（默认 ./data）─────────────────────────
EWA_DATA_DIR=./data
MIAOMIAO_DATA_DIR=./data/miaomiao
# SQLite 数据库路径（建议生产环境用绝对路径，避免多进程 cwd 不一致）
EWA_SITE_DB_PATH=./data/miaomiao.db

# ── 站点 ──────────────────────────────────────────
# 默认博主 slug（需与种子数据一致，当前种子为 ashley）
NEXT_PUBLIC_SITE_SLUG=ashley

# ── CORS 允许的来源（逗号分隔，设为 * 允许全部）─────
EWA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 限流（设为 0 禁用）─────────────────────────────
EWA_RATE_LIMIT=1

# ── 服务器 ────────────────────────────────────────
EWA_HOST=0.0.0.0
EWA_PORT=8000
