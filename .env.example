# 必填：至少配置一个 LLM API Key（妙喵私教首选 Kimi）
MOONSHOT_API_KEY=sk-...
# 回退用
DEEPSEEK_API_KEY=sk-...
# 可选
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# 数据路径（默认 ./data）
EWA_DATA_DIR=./data
MIAOMIAO_DATA_DIR=./data/miaomiao

# CORS 允许的来源（逗号分隔，设为 * 允许全部）
EWA_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 服务器
EWA_HOST=0.0.0.0
EWA_PORT=8000
